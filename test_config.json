{
  "whitelist": ["boss@company.com", "@important-domain.com"],
  "delete_keywords": ["newsletter", "promotion"],
  "keep_keywords": ["contract", "urgent"],
  "recent_threshold_days": 30,
  "old_threshold_days": 365,
  "small_email_threshold": 500,
  "large_email_threshold": 10000,
  "keep_with_attachments": true,
  "type_weights": {
    "newsletter": -2,
    "mailing_list": -1,
    "group": 0,
    "direct": 1,
    "unknown": 0
  }
}
